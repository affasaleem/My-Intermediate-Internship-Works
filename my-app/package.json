{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@skyscanner/backpack-react-scripts": "11.2.4",
    "@skyscanner/backpack-web": "^15.1.0",
    "@skyscanner/cra-template-backpack": "0.0.9",
    "bpk-mixins": "^36.1.1",
    "bpk-stylesheets": "^7.2.16",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "sass": "^1.101.0"
  },
  "scripts": {
    "start": "set NODE_OPTIONS=--max_old_space_size=4096 && react-scripts start",
    "start-ssr": "set NODE_OPTIONS=--max_old_space_size=4096 && react-scripts start-ssr",
    "build": "set NODE_OPTIONS=--max_old_space_size=4096 && react-scripts build",
    "build-ssr": "set NODE_OPTIONS=--max_old_space_size=4096 && react-scripts build-ssr",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "backpack-react-scripts": {
    "babelIncludePrefixes": [
      "./node_modules/@skyscanner/backpack-web"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
